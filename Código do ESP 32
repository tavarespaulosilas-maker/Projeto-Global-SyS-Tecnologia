// Definição de Pinos compatíveis com ESP32
const int TRIG1 = 12; // Sensor Entrada
const int ECHO1 = 13; // Sensor Entrada
const int TRIG2 = 14; // Sensor Saída
const int ECHO2 = 27; // Sensor Saída

int totalPessoas = 0; // Esta variável guarda a contagem

const unsigned long INTERVALO_FILTRO = 1000; // cooldown de 1s por sensor
unsigned long ultimaEntrada = 0;
unsigned long ultimaSaida = 0;

void setup() {
  pinMode(TRIG1, OUTPUT);
  pinMode(ECHO1, INPUT);
  pinMode(TRIG2, OUTPUT);
  pinMode(ECHO2, INPUT);

  Serial.begin(115200);
  Serial.println("Sistema de Contagem ESP32 Iniciado...");
}

long lerDistancia(int trig, int echo) {
  digitalWrite(trig, LOW);
  delayMicroseconds(2);
  digitalWrite(trig, HIGH);
  delayMicroseconds(10);
  digitalWrite(trig, LOW);

  // timeout de 30ms (~5m de alcance) evita travar esperando eco
  long duracao = pulseIn(echo, HIGH, 30000);
  if (duracao == 0) return -1; // nenhum eco detectado dentro do timeout

  return duracao * 0.034 / 2;
}

void loop() {
  unsigned long agora = millis();

  // Lógica para SOMAR (Entrada)
  long distEntrada = lerDistancia(TRIG1, ECHO1);
  if (distEntrada > 0 && distEntrada < 100 && (agora - ultimaEntrada >= INTERVALO_FILTRO)) {
    totalPessoas++;
    ultimaEntrada = agora;
    Serial.print("Alguem entrou! Total agora: ");
    Serial.println(totalPessoas);
  }

  // Lógica para SUBTRAIR (Saída)
  long distSaida = lerDistancia(TRIG2, ECHO2);
  if (distSaida > 0 && distSaida < 100 && totalPessoas > 0 && (agora - ultimaSaida >= INTERVALO_FILTRO)) {
    totalPessoas--;
    ultimaSaida = agora;
    Serial.print("Alguem saiu! Total agora: ");
    Serial.println(totalPessoas);
  }
}
